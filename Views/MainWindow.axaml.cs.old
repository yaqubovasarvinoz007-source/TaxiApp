        public const string SidebarText = "#1E293B";
        public const string CardBg = "#FFFFFF";
        public const string Text = "#1E293B";
        public const string Border = "#E2E8F0";
    }
    
    // Dark Mode
    public static class Dark {
        public const string Background = "#0F172A";
        public const string Sidebar = "#1E293B";
        public const string SidebarText = "#E2E8F0";
        public const string CardBg = "#1E293B";
        public const string Text = "#E2E8F0";
        public const string Border = "#334155";
