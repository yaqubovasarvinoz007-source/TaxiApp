<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TaxiApp.Views.PulYechish"
        Title="Pul Yechish" 
        Width="600" 
        Height="500"
        Background="#F5F5F5">

    <StackPanel Margin="20" Spacing="15">
        <TextBlock Text="Pul Yechish So'rovi" FontSize="24" FontWeight="Bold" Foreground="#333"/>

        <!-- Summa Input -->
        <StackPanel Spacing="5">
            <TextBlock Text="Yechmoqchi Bo'lgan Summa:" Foreground="#666" FontSize="14"/>
            <TextBox x:Name="SummaInput" 
                     Text="{Binding Summa}" 
                     Watermark="Summa kiriting..." 
                     Padding="10"
                     FontSize="14"
                     Height="40"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,20,0,0">
            <Button Content="So'rov Yuborish" 
                    Background="#4CAF50" 
                    Foreground="White" 
                    Padding="15,10"
                    FontSize="14"/>
            <Button Content="Bekor Qilish" 
                    Background="#F44336" 
                    Foreground="White" 
                    Padding="15,10"
                    FontSize="14"/>
        </StackPanel>

        <!-- Yechish Tarixi -->
        <TextBlock Text="Yechish Tarixi" FontSize="16" FontWeight="Bold" Foreground="#333" Margin="0,30,0,0"/>
        
        <ListBox Items="{Binding Yechishlar}" Height="250">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="White" Padding="10" Margin="0,5" CornerRadius="5">
                        <StackPanel Spacing="5">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="{Binding Summa, StringFormat='Summa: {0:C}'}" FontWeight="Bold" Foreground="#2196F3"/>
                                <TextBlock Text="{Binding Holati}" FontWeight="Bold" Foreground="#FF9800"/>
                            </StackPanel>
                            <TextBlock Text="{Binding YechishSana, StringFormat='Sana: {0:dd.MM.yyyy HH:mm}'}" Foreground="#666" FontSize="12"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </StackPanel>
</Window>
